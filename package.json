{
  "name": "ml-llm-engineering-platform",
  "version": "0.1.0",
  "description": "ML/LLM Engineering Platform - Unified provider, model, and config management",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"bun run dev:api\" \"bun run dev:web\"",
    "start": "bun run api",
    "build": "bun run build:core && bun run build:web",
    "build:core": "cd packages/core && bun build src/index.ts --outdir dist --target node --sourcemap --external bun:sqlite",
    "build:web": "cd apps/web && bun run build",
    "api": "bun packages/api/src/index.ts",
    "dev:api": "bun run api",
    "dev:web": "cd apps/web && bun run dev",
    "dev:lens": "cd apps/lens && bun run dev",
    "cli": "bun packages/cli/src/index.ts",
    "db:reset": "rm -f ~/.local/share/ml-engine/engine.db",
    "backup": "bun run cli export save ./backup-$(date +%Y%m%d-%H%M).json"
  },
  "keywords": ["ml", "llm", "ai", "provider", "model", "config", "opencode", "cursor", "baseten", "openrouter", "hono"],
  "author": "sandikodev",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
